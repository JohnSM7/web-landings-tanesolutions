<style is:global>
  [data-reveal] {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease-out;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Setup Intersection Observer for scroll animations
  const setupAnimations = () => {
    const observerOptions = {
      root: null,
      rootMargin: "0px",
      threshold: 0.15,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll("[data-reveal]");
    revealElements.forEach((el) => observer.observe(el));
  };

  // Run on first load and view transitions
  setupAnimations();
  document.addEventListener("astro:page-load", setupAnimations);

  // Form Submission handling
  const contactForm = document.getElementById(
    "contact-form",
  ) as HTMLFormElement;
  const result = document.getElementById("result");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  if (contactForm && result && submitBtn) {
    contactForm.addEventListener("submit", function (e) {
      e.preventDefault();

      // Verify hCaptcha
      const hcaptcha = (
        contactForm.querySelector(
          '[name="h-captcha-response"]',
        ) as HTMLInputElement
      )?.value;
      if (!hcaptcha) {
        result.innerHTML = "Por favor, completa el hCaptcha.";
        result.classList.remove("hidden", "text-brand");
        result.classList.add("text-red-400");
        return;
      }

      const formData = new FormData(contactForm);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      result.innerHTML = "Enviando...";
      result.classList.remove("hidden", "text-red-400", "text-brand");
      result.classList.add("text-slate-400");
      submitBtn.disabled = true;
      submitBtn.classList.add("opacity-50", "cursor-not-allowed");

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.innerHTML = "¡Tu mensaje se ha enviado correctamente!";
            result.classList.remove("text-slate-400", "text-red-400");
            result.classList.add("text-brand", "font-bold");
            contactForm.reset();
            // @ts-ignore
            if (typeof hcaptcha !== "undefined") window.hcaptcha.reset();
          } else {
            console.log(response);
            result.innerHTML =
              json.message || "Algo salió mal. Por favor, inténtalo de nuevo.";
            result.classList.remove("text-slate-400", "text-brand");
            result.classList.add("text-red-400");
          }
        })
        .catch((error) => {
          console.log(error);
          result.innerHTML = "Error de conexión. Inténtalo más tarde.";
          result.classList.remove("text-slate-400", "text-brand");
          result.classList.add("text-red-400");
        })
        .then(function () {
          submitBtn.disabled = false;
          submitBtn.classList.remove("opacity-50", "cursor-not-allowed");
          setTimeout(() => {
            // result.classList.add("hidden");
          }, 5000);
        });
    });
  }
</script>
