---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Demo: Reformas Premium | Tane Solutions" description="Ejemplo de Landing Page para Empresas de Reformas y Construcción.">
  
  <!-- Navigation / Back to Main -->
  <div class="fixed top-0 inset-x-0 z-50 p-4 flex justify-between items-center pointer-events-none">
    <a href="/" class="pointer-events-auto inline-flex items-center gap-2 bg-slate-900/80 backdrop-blur-md border border-slate-700/50 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-slate-800 transition-colors shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Volver a Tane
    </a>
    <div class="pointer-events-auto px-3 py-1 bg-orange-500/10 border border-orange-500/20 text-orange-400 rounded-full text-xs font-bold tracking-widest uppercase">
      Entorno Demo
    </div>
  </div>

  <!-- Hero Section -->
  <main class="min-h-screen bg-slate-950 text-slate-200">
    <!-- Industrial Themed Background Pattern/Gradients -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute inset-0 bg-[#0f1115]"></div> <!-- Darker base -->
      <div class="absolute -top-[10%] left-[20%] w-[60%] h-[40%] bg-orange-600/10 blur-[150px] rounded-full mix-blend-screen"></div>
      
      <!-- Subtle Grid -->
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=')] opacity-30"></div>
    </div>

    <!-- Content -->
    <section class="relative pt-32 pb-20 px-6 lg:px-8 max-w-7xl mx-auto flex flex-col items-center text-center lg:text-left lg:flex-row gap-12 min-h-[90vh]">
      
      <!-- Text Area -->
      <div class="flex-1 relative z-10 lg:pr-10">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-sm bg-orange-500 text-slate-950 font-bold uppercase tracking-wide text-xs mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          Reformas Integrales
        </div>
        
        <h1 class="text-5xl lg:text-7xl font-black uppercase tracking-tighter text-white mb-6 leading-[1.05]">
          Construimos <br/>
          <span class="text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-orange-600">tú futuro.</span>
        </h1>
        
        <p class="text-lg text-slate-400 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed font-medium">
          Especialistas en transformar espacios con materiales premium y acabados impecables. Cumplimos plazos. Sin sorpresas en el presupuesto.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <button class="bg-orange-500 hover:bg-orange-600 text-slate-950 font-black uppercase tracking-wide px-8 py-4 rounded-sm transition-all flex items-center justify-center gap-2">
            Solicitar Presupuesto
          </button>
          <button class="bg-transparent hover:bg-slate-800 text-white border-2 border-slate-700 font-bold uppercase tracking-wide px-8 py-4 rounded-sm transition-all flex items-center justify-center">
            Ver Proyectos
          </button>
        </div>
        
        <div class="mt-8 flex items-center justify-center lg:justify-start gap-4">
            <div class="flex -space-x-2">
              <img class="w-10 h-10 rounded-full border-2 border-slate-900" src="https://i.pravatar.cc/100?img=11" alt="Worker">
              <img class="w-10 h-10 rounded-full border-2 border-slate-900" src="https://i.pravatar.cc/100?img=12" alt="Worker">
              <img class="w-10 h-10 rounded-full border-2 border-slate-900" src="https://i.pravatar.cc/100?img=15" alt="Worker">
            </div>
            <p class="text-sm text-slate-500 font-medium">+50 profesionales en plantilla</p>
        </div>
      </div>

      <!-- Image Area -->
      <div class="flex-1 w-full relative z-10 mt-10 lg:mt-0">
        <div class="relative bg-slate-800 rounded-sm overflow-hidden min-h-[500px] border-l-4 border-orange-500 shadow-2xl">
          <!-- Placeholder Image -->
          <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=2000&auto=format&fit=crop" alt="Construcción Premium" class="absolute inset-0 w-full h-full object-cover opacity-70" />
          
          <div class="absolute inset-0 bg-linear-to-t from-slate-950 via-transparent to-transparent"></div>
          
          <!-- Callout overlay -->
           <div class="absolute bottom-0 inset-x-0 p-8 sm:p-12">
              <div class="bg-orange-500 text-slate-950 inline-block px-4 py-2 font-black text-3xl mb-4 transform -skew-x-12">
                  <span class="block transform skew-x-12">15 AÑOS</span>
              </div>
              <p class="text-white font-bold text-xl uppercase tracking-wider">de experiencia en el sector</p>
           </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
