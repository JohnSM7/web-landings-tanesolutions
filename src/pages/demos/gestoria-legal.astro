---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Demo: Despacho Legal y Gestoría Premium | Tane Solutions" description="Ejemplo de Landing Page para Abogados y Gestorías.">
  
  <!-- Navigation / Back to Main -->
  <div class="fixed top-0 inset-x-0 z-50 p-4 flex justify-between items-center pointer-events-none">
    <a href="/" class="pointer-events-auto inline-flex items-center gap-2 bg-slate-900/80 backdrop-blur-md border border-slate-700/50 text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-slate-800 transition-colors shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Volver a Tane
    </a>
    <div class="pointer-events-auto px-3 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-400 rounded-full text-xs font-bold tracking-widest uppercase">
      Entorno Demo
    </div>
  </div>

  <!-- Hero Section -->
  <main class="min-h-screen bg-slate-950 text-slate-200">
    <!-- Legal Themed Background Gradient -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[10%] -left-[5%] w-[40%] h-[50%] bg-amber-600/5 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[20%] -right-[10%] w-[50%] h-[40%] bg-amber-500/5 blur-[150px] rounded-full"></div>
    </div>

    <!-- Content -->
    <section class="relative pt-32 pb-20 px-6 lg:px-8 max-w-7xl mx-auto flex flex-col lg:flex-row-reverse items-center gap-12 min-h-[90vh]">
      
      <!-- Text Area -->
      <div class="flex-1 relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-500 text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          Asesoría Jurídica y Fiscal
        </div>
        
        <h1 class="text-5xl lg:text-7xl font-serif tracking-tight text-white mb-6 leading-[1.1]">
          Tranquilidad legal para tu <br />
          <span class="text-transparent bg-clip-text bg-linear-to-r from-amber-200 to-amber-500">patrimonio y negocio.</span>
        </h1>
        
        <p class="text-lg text-slate-400 mb-8 max-w-xl leading-relaxed">
          Un equipo de abogados colegiados listos para defender tus intereses con absoluta discreción y eficacia garantizada. Déjanos los problemas a nosotros.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <button class="bg-amber-600 hover:bg-amber-500 text-white font-semibold px-8 py-4 rounded-xl transition-all shadow-lg shadow-amber-600/20 flex items-center justify-center gap-2">
            Consulta Gratuita
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <button class="bg-slate-900 border border-slate-700 hover:border-amber-500/50 text-white font-medium px-8 py-4 rounded-xl transition-all flex items-center justify-center">
            Nuestros Casos
          </button>
        </div>

        <!-- Metric Badges -->
        <div class="mt-12 grid grid-cols-2 gap-6 text-sm text-slate-500 border-t border-slate-800 pt-8 max-w-md">
          <div>
            <p class="text-3xl font-serif text-white mb-1">98%</p>
            <p>Casos Ganados en 2023</p>
          </div>
          <div>
            <p class="text-3xl font-serif text-white mb-1">+15</p>
            <p>Años de Experiencia</p>
          </div>
        </div>
      </div>

      <!-- Image Area -->
      <div class="flex-1 w-full max-w-lg lg:max-w-none relative z-10">
        <div class="relative rounded-4xl overflow-hidden aspect-3/4 sm:aspect-square bg-slate-900 border border-slate-800 shadow-2xl">
          <!-- Placeholder Image -->
          <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?q=80&w=2000&auto=format&fit=crop" alt="Despacho de Abogados" class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay grayscale hover:grayscale-0 transition-all duration-700" />
          
          <div class="absolute inset-0 bg-linear-to-tr from-slate-950 via-slate-900/60 to-transparent"></div>
          
          <!-- Floating UI Element -->
          <div class="absolute top-8 left-8 bg-slate-900/90 backdrop-blur-md border border-slate-700 p-5 rounded-2xl flex items-start gap-4 max-w-[280px]">
            <div class="w-10 h-10 bg-amber-500/20 rounded-full flex items-center justify-center shrink-0">
              <span class="text-amber-500 font-serif font-bold italic">L</span>
            </div>
            <div>
              <p class="text-slate-300 text-sm leading-relaxed">"Su intervención fue clave para resolver la herencia sin pleitos de años."</p>
              <div class="mt-2 flex text-amber-500">★ ★ ★ ★ ★</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
