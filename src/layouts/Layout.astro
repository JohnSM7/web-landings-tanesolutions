---
interface Props {
  title: string;
  description: string;
  hideHeader?: boolean;
}

const { title, description, hideHeader = false } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="es" class="scroll-smooth scroll-pt-20">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Open Graph / SEO Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tanesolutions.com" />
    <meta property="og:image" content="https://tanesolutions.com/og-image.jpg" />
    
    <!-- Modern Typography: Outfit for headers, Inter for body -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">
    
    <!-- Web3Forms hCaptcha Script -->
    <script src="https://web3forms.com/client/script.js" async defer></script>
  </head>
  <body class="bg-slate-900 text-slate-100 font-['Inter',sans-serif] antialiased selection:bg-brand selection:text-slate-900 overflow-x-hidden">
    <!-- Navbar / Header Corporativo -->
    {!hideHeader && (
      <header class="fixed top-0 inset-x-0 z-50 bg-slate-950/80 backdrop-blur-lg border-b border-slate-800 transition-all duration-300">
        <div class="container mx-auto px-6 lg:px-8 h-20 flex items-center justify-between">
          <a href="https://tanesolution.com" class="flex items-center gap-3 group">
            <img src="/logo_tane.png" alt="Tane Solution Logo" class="h-10 w-auto transition-transform group-hover:scale-105" />
          </a>
          
          <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-300">
            <a href="#beneficios" class="hover:text-brand transition-colors">Beneficios</a>
            <a href="#demos" class="hover:text-brand transition-colors">Portfolio</a>
            <a href="#proceso" class="hover:text-brand transition-colors">Cómo funciona</a>
            <a href="#precios" class="hover:text-brand transition-colors">Precios</a>
          </nav>
          
          <div class="flex items-center">
            <a href="#contacto" class="px-5 py-2.5 bg-brand hover:bg-brand/90 text-slate-900 text-sm font-bold rounded-lg transition-transform hover:scale-105 active:scale-95">
              Hablemos
            </a>
          </div>
        </div>
      </header>
    )}

    <div class={hideHeader ? "" : "pt-20"}>
      <slot />
    </div>

    <!-- Footer Corporativo -->
    <footer class="bg-slate-950 border-t border-slate-800 py-12">
      <div class="container mx-auto px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
        <a href="https://tanesolution.com" class="flex items-center gap-2 opacity-80 hover:opacity-100 transition-opacity">
          <img src="/logo_tane.png" alt="Tane Solution Logo" class="h-8 w-auto" />
        </a>
        <div class="text-slate-500 text-sm flex gap-4 md:block">
          &copy; {new Date().getFullYear()} Tane Solution. Diseñado para liderar.
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
  }
</style>
